<?xml version="1.0" encoding="utf-8"?>
<eu.kanade.tachiyomi.ui.reader.settings.NovelTranslationView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/novel_translation_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_rounded_background"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/material_component_dialogs_padding_around_content_area"
        android:paddingEnd="@dimen/material_component_dialogs_padding_around_content_area"
        android:paddingTop="0dp"
        android:paddingBottom="16dp">

        <com.google.android.material.textview.MaterialTextView
            style="?textAppearanceTitleSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/novel_translation_tab"
            android:textColor="?attr/colorSecondary"
            android:textSize="15sp" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/translation_enabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/pref_translation_enabled"
            android:textColor="?attr/colorOnBackground" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/translation_realtime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/pref_translation_realtime"
            android:textColor="?attr/colorOnBackground" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/apply_translation_now"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="start|center_vertical"
            android:text="@string/pref_translation_apply_now"
            app:icon="@drawable/ic_refresh_24dp"
            app:iconGravity="textStart" />

        <com.google.android.material.textview.MaterialTextView
            style="?textAppearanceTitleSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/translation_provider_setup"
            android:textColor="?attr/colorSecondary"
            android:textSize="15sp" />

        <eu.kanade.tachiyomi.widget.MaterialSpinnerView
            android:id="@+id/translation_engine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:title="@string/pref_translation_engine" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/provider_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="?attr/colorOnBackground"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/configure_provider"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="start|center_vertical"
            android:text="@string/pref_translation_configure_provider"
            app:icon="@drawable/ic_outline_settings_24dp"
            app:iconGravity="textStart" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/subscription_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/pref_translation_subscription_note"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp" />

        <com.google.android.material.textview.MaterialTextView
            style="?textAppearanceTitleSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/language"
            android:textColor="?attr/colorSecondary"
            android:textSize="15sp" />

        <eu.kanade.tachiyomi.widget.MaterialSpinnerView
            android:id="@+id/source_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:title="@string/pref_translation_source_language" />

        <eu.kanade.tachiyomi.widget.MaterialSpinnerView
            android:id="@+id/target_language"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:title="@string/pref_translation_target_language" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/source_language_filter"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="start|center_vertical"
            android:text="@string/pref_translation_language_filter"
            app:icon="@drawable/ic_language_24dp"
            app:iconGravity="textStart" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/source_language_filter_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp" />

        <com.google.android.material.textview.MaterialTextView
            style="?textAppearanceTitleSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/pref_translation_mode"
            android:textColor="?attr/colorSecondary"
            android:textSize="15sp" />

        <eu.kanade.tachiyomi.widget.MaterialSpinnerView
            android:id="@+id/translation_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:title="@string/pref_translation_mode" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/smart_auto_translate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/pref_translation_smart_auto"
            android:textColor="?attr/colorOnBackground" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/cache_translations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/pref_translation_cache"
            android:textColor="?attr/colorOnBackground" />

    </LinearLayout>
</eu.kanade.tachiyomi.ui.reader.settings.NovelTranslationView>
